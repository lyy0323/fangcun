# 方寸 — 环境变量配置
# 复制为 .env 并填入实际值

# ---------- 数据库（可选，不设则使用 JSON 文件 / SQLite）----------
# POSTGRES_URL=postgresql://user:pass@host/dbname?sslmode=require

# ---------- 限流（默认关闭）----------
# RATELIMIT_ENABLED=1

# ---------- CDN 下载代理（可选）----------
# CDN_DOMAIN=https://files.example.com
# CDN_AUTH_KEY=your_cdn_auth_key
# APK_PATH=/apk/fangcun_latest.apk

# ---------- Android 签名（构建 APK 时需要）----------
# KEYSTORE_PASSWORD=your_keystore_password
# KEY_PASSWORD=your_key_password
